# Normalize line endings: LF in the repo, platform-native on checkout
* text=auto
# Force LF for all text files (important for cross-platform protocol files)
*.md text eol=lf
*.json text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.py text eol=lf
*.go text eol=lf
*.sh text eol=lf
# Binary files — never convert
*.png binary
*.jpg binary
*.jpeg binary
*.gif filter=lfs diff=lfs merge=lfs -text
*.ico binary
*.webp binary
